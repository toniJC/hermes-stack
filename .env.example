# Hermes Stack — Environment Variables
# Copy this file to .env and fill in your values.
# Real secrets live in ~/.config/litellm/env (sourced by litellm-launch.sh).

# === LiteLLM Proxy ===
ANTHROPIC_API_KEY=sk-ant-...          # Required: Anthropic API key
TOGETHER_API_KEY=...                  # Optional: Together.ai API key
LITELLM_MASTER_KEY=hermes-local-dev   # LiteLLM master key (used by hermes as client key)
OPENAI_API_KEY=dummy                  # Set to real key only if using OpenAI models directly

# === Hermes Docker ===
HERMES_IMAGE=ghcr.io/opencode-ai/opencode:latest   # Docker image for Hermes agent

# === Langfuse Observability ===
NEXTAUTH_SECRET=...                   # Required: random secret for Langfuse auth
POSTGRES_PASSWORD=...                 # Required: Langfuse DB password

# === LiteLLM Launch ===
# LITELLM_BIN=/path/to/litellm        # Override if litellm is not on PATH
