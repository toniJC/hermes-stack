# ~/projects/hermes-docker/.env.example
# Copy to `.env` and edit. `.env` is gitignored.

# Image reference for HermesAgent.
# Default: pinned digest of the official arm64 image (D1).
# Fallback: set to `hermes-agent-local:v2026.5.16` after building Dockerfile.fallback (D2).
HERMES_IMAGE=nousresearch/hermes-agent@sha256:REPLACE_WITH_DIGEST_AT_APPLY_TIME

# Workspace bind-mount. Absolute or relative to docker-compose.yml.
# Switch projects by changing this value (D8).
WORKSPACE_PATH=./projects/miapp

# LiteLLM Management API key — must match LITELLM_MASTER_KEY in ~/.config/litellm/env.
# Default matches the local-dev value baked into the LiteLLM env file.
LITELLM_API_KEY=hermes-local-dev

# OpenAI-compatible API key. mlx_lm.server ignores the value but the OpenAI
# client refuses empty strings, so we ship a literal dummy.
OPENAI_API_KEY=dummy

# Optional MiniMax (TTS/STT) key. Leave empty to disable.
MINIMAX_API_KEY=

# Container timezone (affects log timestamps).
TZ=Europe/Madrid
